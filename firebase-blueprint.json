{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information, wallet balances, and referral settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role." },
        "couponCode": { "type": "string", "description": "Unique referral coupon code." },
        "commissionRate": { "type": "number", "description": "User's commission rate (e.g., 0.05)." },
        "customCommissionRate": { "type": "number", "description": "Override commission rate if set." },
        "isBlocked": { "type": "boolean", "description": "Whether the user is blocked." },
        "isCouponDisabled": { "type": "boolean", "description": "Whether the user's coupon is disabled." },
        "phoneNumber": { "type": "string", "description": "User's phone number." },
        "isProfileComplete": { "type": "boolean", "description": "Whether the user's profile is complete." },
        "wallet": {
          "type": "object",
          "properties": {
            "pending": { "type": "number" },
            "withdrawable": { "type": "number" },
            "totalEarned": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "couponCode", "commissionRate", "wallet", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Stores supplement product information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "category": { "type": "string" },
        "brand": { "type": "string" },
        "goal": { "type": "string", "enum": ["muscle-gain", "fat-loss", "general-health", "performance"] },
        "stock": { "type": "integer" },
        "images": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "numReviews": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Stores customer orders.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalAmount": { "type": "number" },
        "discountAmount": { "type": "number" },
        "couponUsed": { "type": "string" },
        "referralUserId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status", "paymentStatus", "shippingAddress", "createdAt", "updatedAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Stores referral commission records.",
      "type": "object",
      "properties": {
        "couponOwnerId": { "type": "string" },
        "orderId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "earned", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["couponOwnerId", "orderId", "amount", "status", "createdAt"]
    },
    "WithdrawalRequest": {
      "title": "Withdrawal Request",
      "description": "Stores user requests to withdraw earnings.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "upiId": { "type": "string" },
        "bankDetails": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Stores administrative and user activity logs.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "type": { "type": "string", "enum": ["user", "admin"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "userName", "action", "details", "type", "timestamp"]
    },
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "Stores platform-wide configuration parameters.",
      "type": "object",
      "properties": {
        "defaultCommissionRate": { "type": "number" },
        "minWithdrawalAmount": { "type": "number" },
        "whatsappAlerts": { "type": "boolean" },
        "maintenanceMode": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["defaultCommissionRate", "minWithdrawalAmount", "updatedAt"]
    },
    "TrainerSession": {
      "title": "Trainer Session",
      "description": "Stores AI Trainer sessions and plans.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "completed", "expired"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "amount": { "type": "number" },
        "messages": { "type": "array", "items": { "type": "object" } },
        "dietPlan": { "type": "string" },
        "workoutPlan": { "type": "string" },
        "answers": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "status", "paymentStatus", "amount", "messages", "createdAt", "expiresAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profile data." },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog." },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders." },
    "/referrals/{referralId}": { "schema": "Referral", "description": "Referral tracking." },
    "/withdrawals/{withdrawalId}": { "schema": "WithdrawalRequest", "description": "Withdrawal requests." },
    "/audit_logs/{logId}": { "schema": "AuditLog", "description": "System audit logs." },
    "/settings/global": { "schema": "GlobalSettings", "description": "Global platform settings." },
    "/trainer_sessions/{sessionId}": { "schema": "TrainerSession", "description": "AI Trainer sessions." }
  }
}
